{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },

    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      },

      {
        "Name": "File",
        "Args": {
          "restrictedToMinimumLevel": "Error"
        }
      }
    ]
  }
}
